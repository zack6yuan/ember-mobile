rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // A person's profile and their private saved-posts list — owner only.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /saved/{postId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Private moderation state: people you've blocked and posts you've hidden.
      // Owner-only, like saved.
      match /blocked/{blockedUid} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /hidden/{postId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Named authors this person follows (doc id = handle). Owner-only, like saved.
      match /following/{handle} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Warmth notifications. Only the owner may read them or mark them read;
      // any signed-in user may leave one (a hug/heart/reply on the owner's post),
      // but only as themselves — the actorUid must be their own uid.
      match /notifications/{notifId} {
        allow read, update, delete: if request.auth != null && request.auth.uid == uid;
        allow create: if request.auth != null
                      && request.resource.data.actorUid == request.auth.uid;
      }
    }

    // Posts are readable by any signed-in user. You may only create a post as
    // yourself, and only delete your own. Any signed-in user may react or reply,
    // but an update may ONLY touch the reaction/reply fields — never the body,
    // tag, author, or authorUid — so no one can edit someone else's post.
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.authorUid == request.auth.uid;
      allow update: if request.auth != null
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['hugBy', 'heartBy', 'hugs', 'hearts', 'replies']);
      allow delete: if request.auth != null
                    && resource.data.authorUid == request.auth.uid;
    }

    // Live community member counts. Readable by any signed-in user; the only
    // writable field is the `members` tally (a net join/leave delta), so no one
    // can stash anything else on a community doc.
    match /communities/{tag} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.keys().hasOnly(['members']);
      allow update: if request.auth != null
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']);
    }

    // Moderation queue. Any signed-in user may file a report as themselves, but
    // no client may read, edit, or delete reports — the queue is reviewed in the
    // Firebase console, never enumerable from the app.
    match /reports/{reportId} {
      allow create: if request.auth != null
                    && request.resource.data.reporterUid == request.auth.uid;
      allow read, update, delete: if false;
    }
  }
}
