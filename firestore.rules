rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // A person's profile and their private saved-posts list — owner only.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /saved/{postId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Posts are readable by any signed-in user. You may only create a post as
    // yourself, and only delete your own. Updates (reactions + replies) are open
    // to any signed-in user.
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.authorUid == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if request.auth != null
                    && resource.data.authorUid == request.auth.uid;
    }
  }
}
